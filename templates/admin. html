{% extends "base.html" %}
{% block title %}Admin — ShopSphere{% endblock %}

{% block content %}
<div class="container">

  <div class="admin-header fade-up">
    <p class="product-category" style="margin-bottom:8px;">Administration</p>
    <h1 style="font-family:'Playfair Display',serif;">Admin Panel</h1>
  </div>

  <div class="stat-cards fade-up">
    <div class="stat-card">
      <div class="stat-card-num">{{ products | length }}</div>
      <div class="stat-card-label">Total products</div>
    </div>
    <div class="stat-card">
      <div class="stat-card-num">{{ users | length }}</div>
      <div class="stat-card-label">Registered users</div>
    </div>
    <div class="stat-card">
      <div class="stat-card-num">{{ orders | length }}</div>
      <div class="stat-card-label">Total orders</div>
    </div>
  </div>

  <div class="admin-tabs fade-up">
    <button class="tab-btn active" onclick="switchTab('products', this)">Products</button>
    <button class="tab-btn" onclick="switchTab('add', this)">Add Product</button>
    <button class="tab-btn" onclick="switchTab('users', this)">Users</button>
    <button class="tab-btn" onclick="switchTab('orders', this)">Orders</button>
  </div>

  <div id="tab-products" class="tab-panel active fade-up">
    <div class="card" style="overflow-x:auto; padding:0;">
      <table class="admin-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Category</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          {% for p in products %}
            <tr>
              <td class="text-muted">#{{ p.id }}</td>
              <td class="text-bold">{{ p.name }}</td>
              <td>
                <span class="badge badge-amber">{{ p.category }}</span>
              </td>
              <td class="text-bold">${{ "%.2f"|format(p.price) }}</td>
              <td class="text-bold {% if p.stock < 5 %}stock-low{% else %}stock-ok{% endif %}">
                {{ p.stock }}
              </td>
              <td>
                <form method="POST" action="{{ url_for('admin_delete_product', product_id=p.id) }}"
                      onsubmit="return confirm('Delete this product?')">
                  <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                </form>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  <div id="tab-add" class="tab-panel fade-up">
    <div class="add-product-form" style="max-width:640px;">
      <h3 style="font-family:'Playfair Display',serif; font-size:22px; margin-bottom:24px;">Add New Product</h3>
      <form method="POST" action="{{ url_for('admin_add_product') }}">
        <div class="form-row">
          <div class="form-group">
            <label>Product name</label>
            <input type="text" name="name" class="form-control" placeholder="e.g. Leather Belt" required />
          </div>
          <div class="form-group">
            <label>Category</label>
            <input type="text" name="category" class="form-control" placeholder="e.g. Accessories" required />
          </div>
        </div>
        <div class="form-group">
          <label>Description</label>
          <input type="text" name="description" class="form-control" placeholder="Brief product description" />
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Price (USD)</label>
            <input type="number" name="price" class="form-control" placeholder="29.99" step="0.01" min="0" required />
          </div>
          <div class="form-group">
            <label>Stock quantity</label>
            <input type="number" name="stock" class="form-control" placeholder="100" min="0" required />
          </div>
        </div>
        <div class="form-group">
          <label>Image URL</label>
          <input type="url" name="image_url" class="form-control" placeholder="https://images.unsplash.com/..." />
        </div>
        <button type="submit" class="btn btn-primary" style="margin-top:8px;">Add Product</button>
      </form>
    </div>
  </div>

  <div id="tab-users" class="tab-panel fade-up">
    <div class="card" style="overflow-x:auto; padding:0;">
      <table class="admin-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Username</th>
            <th>Email</th>
            <th>Role</th>
          </tr>
        </thead>
        <tbody>
          {% for u in users %}
            <tr>
              <td class="text-muted">#{{ u.id }}</td>
              <td class="text-bold">{{ u.username }}</td>
              <td class="text-muted">{{ u.email }}</td>
              <td>
                {% if u.is_admin %}
                  <span class="badge badge-amber">Admin</span>
                {% else %}
                  <span class="badge badge-muted">User</span>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  <div id="tab-orders" class="tab-panel fade-up" style="margin-bottom:80px;">
    <div class="card" style="overflow-x:auto; padding:0;">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Order #</th>
            <th>Customer</th>
            <th>Total</th>
            <th>Status</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          {% for o in orders %}
            <tr>
              <td class="text-bold">#{{ "%04d"|format(o.id) }}</td>
              <td>{{ o.username }}</td>
              <td class="text-amber text-bold">${{ "%.2f"|format(o.total) }}</td>
              <td><span class="badge badge-{{ o.status }}">{{ o.status | capitalize }}</span></td>
              <td class="text-muted text-sm">{{ o.created_at[:10] }}</td>
            </tr>
          {% endfor %}
          {% if not orders %}
            <tr>
              <td colspan="5" class="text-center text-muted" style="padding:40px;">No orders yet.</td>
            </tr>
          {% endif %}
        </tbody>
      </table>
    </div>
  </div>

</div>
{% endblock %}

{% block scripts %}
<script>
  function switchTab(name, btn) {
    document.querySelectorAll('.tab-panel').forEach(function(p) {
      p.classList.remove('active');
    });
    document.querySelectorAll('.tab-btn').forEach(function(b) {
      b.classList.remove('active');
    });
    document.getElementById('tab-' + name).classList.add('active');
    btn.classList.add('active');
  }
</script>
{% endblock %}